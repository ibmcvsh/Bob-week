# ODM Generated/Compiled Artifacts - Can be rebuilt
# These files are generated by IBM ODM Build Command and should not be committed

# Rule Project Output
*/*/output/
*/*/reports/

# XOM Compiled Classes
*/*-xom/classes/

# XOM Compiled JARs
*/*-xom/*-xom-*.jar

# XOM Library Resources (copied from XOM project)
*/*/resources/xom-libraries/*.zip

# Eclipse Sync Entries
**/.syncEntries

# Build artifacts
*.dsar
*.sem

