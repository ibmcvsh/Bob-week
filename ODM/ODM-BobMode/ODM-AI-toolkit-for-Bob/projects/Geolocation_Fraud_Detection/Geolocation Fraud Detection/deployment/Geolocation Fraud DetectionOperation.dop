      validator="Default Validator"/>

  <targetRuleProject href="../../Geolocation%20Fraud%20Detection#a3f1e2d4-7b8c-4a9e-b012-3c4d5e6f7a8b"/>

</com.ibm.rules.studio.model.decisionservice:Operation>