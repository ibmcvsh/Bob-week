<sample_data_generation>
  <overview>
    Guidelines for generating realistic, contextual sample data for BAW widget testing.
    Sample data should be meaningful, varied, and representative of real-world usage.
  </overview>

  <core_principles>
    <principle>Data should match the widget's purpose and context</principle>
    <principle>Use realistic values, not placeholder text</principle>
    <principle>Include variety to test different states</principle>
    <principle>Maintain data consistency across related widgets</principle>
    <principle>Consider edge cases and boundary conditions</principle>
  </core_principles>

  <data_generation_strategies>
    <strategy name="contextual_naming">
      <description>Generate field values based on field names and semantics</description>
      <examples>
        <example>
          <field>employeeName</field>
          <good>"Sarah Johnson", "Michael Chen", "Aisha Patel"</good>
          <bad>"Test User 1", "User 2", "XXX"</bad>
        </example>
        <example>
          <field>orderDate</field>
          <good>"2026-05-01", "2026-04-28", "2026-05-03"</good>
          <bad>"2020-01-01", "1999-12-31", "Date"</bad>
        </example>
        <example>
          <field>status</field>
          <good>"In Progress", "Completed", "Pending Review"</good>
          <bad>"Status1", "S", "XXX"</bad>
        </example>
      </examples>
    </strategy>

    <strategy name="realistic_ranges">
      <description>Use appropriate value ranges for numeric data</description>
      <examples>
        <example>
          <field>percentage (0-100)</field>
          <values>0, 25, 50, 75, 100</values>
          <avoid>-10, 150, 999</avoid>
        </example>
        <example>
          <field>age</field>
          <values>25, 34, 42, 58, 67</values>
          <avoid>0, 200, -5</avoid>
        </example>
        <example>
          <field>price</field>
          <values>19.99, 149.50, 2499.00</values>
          <avoid>0.01, 999999.99</avoid>
        </example>
      </examples>
    </strategy>

    <strategy name="state_variety">
      <description>Generate data representing different states</description>
      <states>
        <state>Empty/Initial state</state>
        <state>Partially complete</state>
        <state>Fully complete</state>
        <state>Error/Invalid state</state>
        <state>Edge cases</state>
      </states>
      <example widget="ProgressBar">
        <state name="not_started">
          <data>currentStep: 0, totalSteps: 5, percentage: 0</data>
        </state>
        <state name="in_progress">
          <data>currentStep: 3, totalSteps: 5, percentage: 60</data>
        </state>
        <state name="complete">
          <data>currentStep: 5, totalSteps: 5, percentage: 100</data>
        </state>
      </example>
    </strategy>

    <strategy name="relational_consistency">
      <description>Maintain logical relationships between data fields</description>
      <examples>
        <example>
          <scenario>Progress tracking</scenario>
          <consistent>
            currentStep: 3
            totalSteps: 5
            percentage: 60 (calculated: 3/5 * 100)
            label: "Step 3 of 5"
          </consistent>
          <inconsistent>
            currentStep: 3
            totalSteps: 5
            percentage: 25 (doesn't match 3/5)
            label: "Almost done" (doesn't match 60%)
          </inconsistent>
        </example>
      </examples>
    </strategy>
  </data_generation_strategies>

