  <data_generation_workflow>
    <step number="1">
      <action>Analyze business object structure</action>
      <details>Read the business object JSON file to understand field types and structure</details>
    </step>

    <step number="2">
      <action>Understand widget purpose</action>
      <details>Determine what the widget does and what kind of data makes sense</details>
    </step>

    <step number="3">
      <action>Generate contextual values</action>
      <details>Create realistic values based on field names and widget purpose</details>
    </step>

    <step number="4">
      <action>Ensure consistency</action>
      <details>Verify that related fields have logically consistent values</details>
    </step>

    <step number="5">
      <action>Add variety</action>
      <details>Create multiple instances showing different states if appropriate</details>
    </step>
  </data_generation_workflow>

  <common_data_patterns>
    <pattern name="names">
      <examples>Sarah Johnson, Michael Chen, Aisha Patel, Carlos Rodriguez, Emma Williams</examples>
    </pattern>

    <pattern name="dates">
      <format>YYYY-MM-DD (ISO 8601)</format>
      <examples>2026-05-03, 2026-04-15, 2026-06-30</examples>
      <avoid>Use current year, not old dates like 2020</avoid>
    </pattern>

    <pattern name="statuses">
      <examples>Active, Pending, Complete, In Progress, On Hold, Cancelled</examples>
    </pattern>

    <pattern name="labels">
      <examples>Processing documents..., Uploading files..., Verifying information..., Almost done!</examples>
    </pattern>

    <pattern name="descriptions">
      <examples>Annual financial report for fiscal year 2026, Quarterly sales analysis and projections</examples>
    </pattern>
  </common_data_patterns>

  <presentation_format>
    <format>
      When presenting sample data to the user:

      **Sample Data Generated:**

      **[Widget Name]** ([Business Object])
      ```json
      {
        "field1": "value1",
        "field2": value2,
        ...
      }
      ```

      **Data Rationale:**
      - [Reason for these values]
      - [How it represents realistic usage]
      - [What states it covers]
    </format>
  </presentation_format>
</sample_data_generation>

