        "  Text (field 1)",
        "  Text (field 2)",
        "  Text Area (field 3)",
        "  Button (submit)"
      ]
    },
    "multi_section_form": {
      "description": "Form organized into logical sections",
      "structure": [
        "Panel (Section 1)",
        "  Text fields...",
        "Panel (Section 2)",
        "  Date Picker, Select...",
        "Horizontal Layout (Actions)",
        "  Button (Submit)",
        "  Button (Cancel)"
      ]
    },
    "claims_form_example": {
      "description": "Insurance claims form with 10 fields",
      "sections": {
        "claimant_info": {
          "widgets": ["Text", "Text", "Text", "Text"],
